{
  "manifest_version": 3,
  "name": "SKVK Autofill Assistant",
  "version": "1.0.0",
  "description": "Fills job application forms from your saved profile and a growing Q&A bank, asking Gemini to draft an answer the first time it sees a new question.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://system-al.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SKVK Autofill"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
