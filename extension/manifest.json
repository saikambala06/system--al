{
  "manifest_version": 3,
  "name": "JobFill AI - Auto Fill Job Applications",
  "version": "1.0.0",
  "description": "AI-powered auto-fill for job application forms. Fill any job application in one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://ai-jb.vercel.app/*", "https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JobFill AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
