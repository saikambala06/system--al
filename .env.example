# MongoDB Atlas connection string (Database > Connect > Drivers)
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/skvk?retryWrites=true&w=majority
MONGODB_URI=

# Any long random string - used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional - override if the default model gets deprecated.
# See https://ai.google.dev/gemini-api/docs/models for current options.
GEMINI_MODEL=gemini-3.5-flash

# Local dev only
PORT=5000
